        <mxCell id="s1b" value="&lt;b&gt;Node.js / Express Backend&lt;/b&gt;&#xa;stemlab-drinks-backend-1&#xa;Helmet CSP | Rate limiting&#xa;5 PIN attempts / 15min&#xa;20 orders / 10min" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede7f6;strokeColor=#4527a0;fontColor=#311b92;fontSize=11;" vertex="1" parent="s1">
