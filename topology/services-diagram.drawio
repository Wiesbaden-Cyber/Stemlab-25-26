        <!-- API endpoints box -->
        <mxCell id="s1d" value="&lt;b&gt;API Endpoints&lt;/b&gt;&#xa;POST /api/auth                   — verify admin PIN&#xa;GET  /api/menu                   — list drinks (public)&#xa;POST /api/menu                   — add drink (admin)&#xa;PATCH /api/menu/:id              — edit drink (admin)&#xa;DELETE /api/menu/:id             — remove drink (admin)&#xa;POST /api/orders                 — place order (public, rate-limited)&#xa;GET  /api/orders                 — list all orders (admin)&#xa;PATCH /api/orders/:id/fulfill    — mark fulfilled (admin)&#xa;PATCH /api/orders/:id/cancel     — cancel order (admin)&#xa;DELETE /api/orders               — flush all orders (admin)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#880e4f;fontColor=#880e4f;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="s1">
          <mxGeometry x="20" y="175" width="660" height="120" as="geometry" />
        </mxCell>

